# Anthropic API
ANTHROPIC_API_KEY=sk-ant-api03-...
# Default model for agents (cheaper for dev). Switch to claude-sonnet-4-6 only for demo recording.
AGENT_MODEL=claude-haiku-4-5-20251001

# Database
DATABASE_URL=postgresql+psycopg://pulse:pulse_dev@localhost:5432/portfolio_pulse

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Auth
JWT_SECRET=change-me-in-prod-32-chars-minimum-please

# SCIM 2.0 - IdP (Okta/Azure AD) bearer token to authenticate /scim/v2/* calls
SCIM_BEARER_TOKEN=scim-dev-bearer-please-rotate-in-prod

# Slack
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_PORTFOLIO_CHANNEL=portfolio-pulse
